MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=laaride
SECRET_KEY=your-super-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
IS_DEVELOPMENT=True
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_KEY=

# Redis — controls rate limiter backend
# Leave REDIS_URL empty → in-memory rate limiting (no Redis needed)
# Set REDIS_URL → Redis-backed rate limiting (works with Upstash in dev too)
REDIS_URL=
# To use Upstash Redis in dev, uncomment and fill:
# REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379
RATE_LIMIT_ENABLED=true

ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8081"]
LOG_LEVEL=INFO
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Backblaze B2 (optional — leave empty for local file storage)
BACKBLAZE_KEY_ID=
BACKBLAZE_APPLICATION_KEY=
BACKBLAZE_BUCKET_NAME=
BACKBLAZE_REGION=us-west-004
