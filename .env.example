# App
IS_DEVELOPMENT=false
LOG_LEVEL=INFO
SECRET_KEY=generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# MongoDB Atlas
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=laaride

# Upstash Redis
REDIS_URL=rediss://<user>:<password>@<host>.upstash.io:6379
RATE_LIMIT_ENABLED=true

# CORS — update with your actual domains
ALLOWED_ORIGINS=["https://yourdomain.com","https://admin.yourdomain.com"]

# Firebase FCM
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_KEY=

# Fast2SMS — get free API key at https://fast2sms.com (Dashboard > Dev API)
FAST2SMS_API_KEY=

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Backblaze B2
BACKBLAZE_KEY_ID=
BACKBLAZE_APPLICATION_KEY=
BACKBLAZE_BUCKET_NAME=laaride-uploads
BACKBLAZE_REGION=us-west-004
